<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.MainPage"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <Label Text="Return to Monkee"
                   FontSize="32"
                   FontAttributes="Bold" />

            <Label Text="Tagesstatus"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Button x:Name="RefreshButton"
                    Text="Dashboard aktualisieren"
                    Clicked="OnRefreshClicked" />

            <Border Stroke="LightGray"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="16">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Deine Ziele"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <Label x:Name="GoalsEmptyLabel"
                           Text="Noch keine Ziele ausgewählt."
                           TextColor="Gray" />

                    <CollectionView x:Name="GoalsCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10"
                                      Padding="0,4">
                                    <Image HeightRequest="20"
                                           WidthRequest="20"
                                           VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource FontFamily="FontAwesomeSolid"
                                                             Glyph="{Binding Glyph}"
                                                             Size="18"
                                                             Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                                        </Image.Source>
                                    </Image>
                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           FontSize="15"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="LightGray"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="16">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Aktive Regeln"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <Label x:Name="ActiveRulesEmptyLabel"
                           Text="Keine aktiven Regeln gefunden."
                           TextColor="Gray" />

                    <CollectionView x:Name="ActiveRulesCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="LightGray"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 8"
                                        Padding="12"
                                        Margin="0,4">

                                    <Grid ColumnDefinitions="*,Auto"
                                          RowDefinitions="Auto,Auto"
                                          ColumnSpacing="12">

                                        <Label Text="{Binding Title}"
                                               FontAttributes="Bold"
                                               FontSize="16" />

                                        <Label Grid.Column="1"
                                               Text="{Binding Kind}"
                                               FontSize="12"
                                               TextColor="Gray" />

                                        <Label Grid.Row="1"
                                               Grid.ColumnSpan="2"
                                               Text="{Binding Description}"
                                               FontSize="13"
                                               TextColor="Gray" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="LightGray"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="16">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Nächste Reminder"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <Label x:Name="SleepReminderLabel"
                           Text="Schlafenszeit wird geladen..." />

                    <Label x:Name="MovementReminderLabel"
                           Text="Bewegungserinnerung wird geladen..." />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="LightGray"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 12"
                    Padding="16">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Heutige Statistik"
                           FontSize="20"
                           FontAttributes="Bold" />

                    <Label x:Name="TodaySummaryLabel"
                           Text="Statistik wird geladen..." />

                    <Label x:Name="ReminderStatsLabel"
                           TextColor="Gray" />

                    <Label x:Name="LimitStatsLabel"
                           TextColor="Gray" />
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ErrorLabel"
                   TextColor="Red"
                   IsVisible="False" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>