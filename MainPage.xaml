<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.MainPage"
             Title="Dashboard"
             BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}">

    <ContentPage.Resources>
        <!-- Karten und Ueberschriften im App-Stil (warmes Beige / Salbei, Dark-first),
             analog zu Statistik- und Regel-Seite. Alle Karten mit beiger Border. -->
        <Style x:Key="DashCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmSurface}, Dark={StaticResource Gray900}}" />
            <Setter Property="Stroke" Value="{StaticResource WarmStroke}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        </Style>

        <Style x:Key="CardHeading" TargetType="Label">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
        </Style>

        <Style x:Key="CardBody" TargetType="Label">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
        </Style>

        <Style x:Key="CardMuted" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
        </Style>

        <!-- Kennzahl-Kachel: dunkler/heller abgesetzt gegenueber der Karte, Wert farbig. -->
        <Style x:Key="StatTile" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmSurfaceAlt}, Dark={StaticResource Gray950}}" />
            <Setter Property="Stroke" Value="{StaticResource WarmStroke}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="10,10" />
            <Setter Property="StrokeShape" Value="RoundRectangle 10" />
        </Style>

        <Style x:Key="TileCaption" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="HorizontalOptions" Value="Center" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
        </Style>

        <Style x:Key="TileValue" TargetType="Label">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalOptions" Value="Center" />
        </Style>

        <!-- Pillen-Badge (z. B. naechster Reminder-Zeitpunkt). Farbe wird im Code je Zustand gesetzt. -->
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="StrokeShape" Value="RoundRectangle 14" />
            <Setter Property="VerticalOptions" Value="Center" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24,28,24,24" Spacing="16">

            <!-- Kopfbereich: Monkey + Titel -->
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                <Image Source="monkey_face_svgrepo.png"
                       HeightRequest="52"
                       WidthRequest="52"
                       VerticalOptions="Center" />
                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Return to Monkee"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                    <Label Text="Dein Tagesstatus"
                           Style="{StaticResource CardMuted}" />
                </VerticalStackLayout>
            </Grid>

            <Button x:Name="RefreshButton"
                    Text="Dashboard aktualisieren"
                    Clicked="OnRefreshClicked"
                    HorizontalOptions="Fill"
                    BackgroundColor="Transparent"
                    BorderWidth="1"
                    BorderColor="{StaticResource WarmStroke}"
                    TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}">
                <Button.ImageSource>
                    <FontImageSource FontFamily="FontAwesomeSolid"
                                     Glyph="&#xf021;"
                                     Size="14"
                                     Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                </Button.ImageSource>
            </Button>

            <!-- Deine Ziele (FR-06) -->
            <Border Style="{StaticResource DashCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Deine Ziele" Style="{StaticResource CardHeading}" />

                    <Label x:Name="GoalsEmptyLabel"
                           Text="Noch keine Ziele ausgewählt."
                           Style="{StaticResource CardMuted}" />

                    <CollectionView x:Name="GoalsCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="10"
                                      Padding="0,4">
                                    <Image HeightRequest="20"
                                           WidthRequest="20"
                                           VerticalOptions="Center">
                                        <Image.Source>
                                            <FontImageSource FontFamily="FontAwesomeSolid"
                                                             Glyph="{Binding Glyph}"
                                                             Size="18"
                                                             Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                                        </Image.Source>
                                    </Image>
                                    <Label Grid.Column="1"
                                           Text="{Binding Title}"
                                           Style="{StaticResource CardBody}"
                                           FontSize="15"
                                           VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Aktive Regeln -->
            <Border Style="{StaticResource DashCard}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Aktive Regeln" Style="{StaticResource CardHeading}" />

                    <Label x:Name="ActiveRulesEmptyLabel"
                           Text="Keine aktiven Regeln gefunden."
                           Style="{StaticResource CardMuted}" />

                    <CollectionView x:Name="ActiveRulesCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="{AppThemeBinding Light={StaticResource WarmSurfaceAlt}, Dark={StaticResource Gray950}}"
                                        Stroke="{StaticResource WarmStroke}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 10"
                                        Padding="12"
                                        Margin="0,4">

                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12">

                                        <Image Grid.RowSpan="2"
                                               HeightRequest="20"
                                               WidthRequest="20"
                                               VerticalOptions="Start"
                                               Margin="0,2,0,0">
                                            <Image.Source>
                                                <FontImageSource FontFamily="FontAwesomeSolid"
                                                                 Glyph="&#xf017;"
                                                                 Size="18"
                                                                 Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                                            </Image.Source>
                                        </Image>

                                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                                            <Label Text="{Binding Title}"
                                                   FontAttributes="Bold"
                                                   FontSize="16"
                                                   TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                                            <Label Text="{Binding Description}"
                                                   FontSize="13"
                                                   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="2"
                                                Style="{StaticResource Pill}"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource WarmSelected}, Dark={StaticResource WarmSelected}}"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Kind}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource White}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- Nächste Reminder -->
            <Border Style="{StaticResource DashCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Nächste Reminder" Style="{StaticResource CardHeading}" />

                    <!-- Schlaf -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Image HeightRequest="22" WidthRequest="22" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource FontFamily="FontAwesomeSolid"
                                                 Glyph="&#xf186;"
                                                 Size="20"
                                                 Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                            </Image.Source>
                        </Image>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Schlafenszeit" Style="{StaticResource CardBody}" FontAttributes="Bold" />
                            <Label x:Name="SleepReminderDetailLabel" Style="{StaticResource CardMuted}" />
                        </VerticalStackLayout>
                        <Border x:Name="SleepReminderBadge" Grid.Column="2" Style="{StaticResource Pill}">
                            <Label x:Name="SleepReminderBadgeLabel" FontSize="13" FontAttributes="Bold" />
                        </Border>
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource WarmStroke}" />

                    <!-- Bewegung -->
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Image HeightRequest="22" WidthRequest="22" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource FontFamily="FontAwesomeSolid"
                                                 Glyph="&#xf554;"
                                                 Size="20"
                                                 Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                            </Image.Source>
                        </Image>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Bewegung" Style="{StaticResource CardBody}" FontAttributes="Bold" />
                            <Label x:Name="MovementReminderDetailLabel" Style="{StaticResource CardMuted}" />
                        </VerticalStackLayout>
                        <Border x:Name="MovementReminderBadge" Grid.Column="2" Style="{StaticResource Pill}">
                            <Label x:Name="MovementReminderBadgeLabel" FontSize="13" FontAttributes="Bold" />
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Heutige Statistik -->
            <Border Style="{StaticResource DashCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Heutige Statistik" Style="{StaticResource CardHeading}" />

                    <!-- Reminder -->
                    <Label Text="Reminder" Style="{StaticResource CardMuted}" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border Grid.Column="0" Style="{StaticResource StatTile}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="✓ Bestätigt" Style="{StaticResource TileCaption}" />
                                <Label x:Name="StatReminderConfirmed"
                                       Style="{StaticResource TileValue}"
                                       TextColor="{StaticResource WarmSelected}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource StatTile}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="✕ Ignoriert" Style="{StaticResource TileCaption}" />
                                <Label x:Name="StatReminderIgnored"
                                       Style="{StaticResource TileValue}"
                                       TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatTile}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Quote" Style="{StaticResource TileCaption}" />
                                <Label x:Name="StatReminderRate"
                                       Style="{StaticResource TileValue}"
                                       TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Zeitlimits -->
                    <Label Text="Zeitlimits" Style="{StaticResource CardMuted}" FontAttributes="Bold" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Border Grid.Column="0" Style="{StaticResource StatTile}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="✓ Eingehalten" Style="{StaticResource TileCaption}" />
                                <Label x:Name="StatLimitsKept"
                                       Style="{StaticResource TileValue}"
                                       TextColor="{StaticResource WarmSelected}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource StatTile}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="✕ Überschritten" Style="{StaticResource TileCaption}" />
                                <Label x:Name="StatLimitsExceeded"
                                       Style="{StaticResource TileValue}"
                                       TextColor="{StaticResource WarmDanger}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource StatTile}">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Quote" Style="{StaticResource TileCaption}" />
                                <Label x:Name="StatLimitRate"
                                       Style="{StaticResource TileValue}"
                                       TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label x:Name="ErrorLabel"
                   TextColor="{StaticResource WarmDanger}"
                   IsVisible="False" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
