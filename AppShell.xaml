<?xml version="1.0" encoding="UTF-8" ?>
<Shell
	x:Class="ReturnToMonkee.AppShell"
	xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
	xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
	xmlns:onboarding="clr-namespace:ReturnToMonkee.Features.Onboarding"
	xmlns:home="clr-namespace:ReturnToMonkee"
	xmlns:interventions="clr-namespace:ReturnToMonkee.Features.Interventions"
	xmlns:personTest="clr-namespace:ReturnToMonkee.Features.PersonTest"
    xmlns:statistics="clr-namespace:ReturnToMonkee.Features.Statistics"
	xmlns:rules="clr-namespace:ReturnToMonkee.Features.Rules"
	Title="ReturnToMonkee"
	FlyoutBackdrop="Transparent"
	FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource WarmSurface}, Dark={StaticResource Gray950}}">

	<Shell.Resources>
		<!-- Flyout-Eintraege im App-Stil: transparent normal, Salbei ausgewaehlt -->
		<Style TargetType="Layout"
			   ApplyToDerivedTypes="True"
			   Class="FlyoutItemLayoutStyle">
			<Setter Property="VisualStateManager.VisualStateGroups">
				<VisualStateGroupList>
					<VisualStateGroup x:Name="CommonStates">
						<VisualState x:Name="Normal">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="Transparent" />
							</VisualState.Setters>
						</VisualState>
						<VisualState x:Name="Selected">
							<VisualState.Setters>
								<Setter Property="BackgroundColor" Value="{StaticResource WarmSelected}" />
							</VisualState.Setters>
						</VisualState>
					</VisualStateGroup>
				</VisualStateGroupList>
			</Setter>
		</Style>
	</Shell.Resources>

	<!-- Header verhindert, dass die Flyout-Eintraege unter die Android-Statusbar rutschen
	     (Top-Padding = Statusbar-Inset) und gibt dem Menue einen sauberen Kopfbereich. -->
	<Shell.FlyoutHeader>
		<Grid Padding="20,12,20,16"
			  ColumnDefinitions="Auto,*"
			  ColumnSpacing="12"
			  BackgroundColor="{AppThemeBinding Light={StaticResource WarmSurface}, Dark={StaticResource Gray950}}">
			<Image Source="monkey_face_svgrepo.png"
				   HeightRequest="40"
				   WidthRequest="40"
				   VerticalOptions="Center" />
			<Label Grid.Column="1"
				   Text="Return to Monkee"
				   FontSize="18"
				   FontAttributes="Bold"
				   VerticalOptions="Center"
				   TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
		</Grid>
	</Shell.FlyoutHeader>

	<ShellContent
		Route="onboarding"
		FlyoutItemIsVisible="False"
		ContentTemplate="{DataTemplate onboarding:GoalOrientationView}" />

	<ShellContent
		x:Name="HomeShellContent"
		Title="Home"
		Route="home"
		ContentTemplate="{DataTemplate home:MainPage}" />

	<ShellContent
		x:Name="RulesShellContent"
		Title="Regeln"
		Route="RulesPage"
		ContentTemplate="{DataTemplate rules:RulesPage}" />

	<ShellContent
		x:Name="InterventionShellContent"
		Title="Intervention"
		Route="TimeLimitInterventionPage"
		ContentTemplate="{DataTemplate interventions:TimeLimitInterventionPage}" />

    <ShellContent 
    x:Name="StatisticsShellContent"
    Title="Statistiken" 
    Route="statistics" 
    ContentTemplate="{DataTemplate statistics:StatisticsView}" />

    <ShellContent
		x:Name="SettingsShellContent"
		Title="Einstellungen"
		Route="SettingsPage" />

	<!-- Test-Feature: aus dem Menue ausgeblendet, bleibt aber als Route erreichbar.
	     Bewusst als letzte ShellContent, damit sie nicht als Startseite aufblitzt. -->
	<ShellContent
		x:Name="PersonListShellContent"
		Title="Personen"
		Route="PersonListPage"
		FlyoutItemIsVisible="False"
		ContentTemplate="{DataTemplate personTest:PersonListPage}" />

</Shell>
