<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Settings.SettingsPage"
             Title="Einstellungen">
    <VerticalStackLayout Padding="24" Spacing="20">
        <Label Text="Einstellungen"
               FontSize="22"
               FontAttributes="Bold" />

        <!-- Schlafenszeit (#17) -->
        <Grid ColumnDefinitions="*,Auto"
              RowDefinitions="Auto,Auto"
              RowSpacing="8">
            <Label Text="Schlafenszeit"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <Label x:Name="SleepTimeLabel"
                   Grid.Column="1"
                   VerticalOptions="Center"
                   Text="–" />
            <Button Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Text="Schlafenszeit ändern"
                    HorizontalOptions="Start"
                    Clicked="OnEditSleepTimeClicked" />
        </Grid>

        <!-- Platzhalter für #18: Bewegungsintervall -->

        <!-- Entwickler-Option: Onboarding erneut anzeigen -->
        <HorizontalStackLayout Spacing="8">
            <CheckBox x:Name="ShowOnboardingOnStartupCheckBox"
                      CheckedChanged="OnShowOnboardingOnStartupCheckedChanged" />
            <Label Text="Onboarding beim App-Start anzeigen (Entwicklung)"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>
