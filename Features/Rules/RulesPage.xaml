<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Rules.RulesPage"
             Title="Regeln">
    <CollectionView ItemsSource="{Binding Rules}" SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Grid Padding="12" ColumnDefinitions="*,Auto">
                    <StackLayout>
                        <Label Text="{Binding Title}" FontAttributes="Bold" />
                        <Label Text="{Binding Description}" FontSize="Small" />
                    </StackLayout>
                    <Switch Grid.Column="1" IsToggled="{Binding IsEnabled}" Toggled="Switch_Toggled" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>