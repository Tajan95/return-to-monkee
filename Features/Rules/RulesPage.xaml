<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Rules.RulesPage"
             Title="Regeln">
    <ContentPage.Resources>
        <Style x:Key="RuleCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmSurface}, Dark={StaticResource Gray900}}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="12">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Rules}" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource RuleCard}" Margin="0,0,0,12">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                            <Grid Grid.Column="0" BackgroundColor="Transparent">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="Item_Tapped" />
                                </Grid.GestureRecognizers>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" FontSize="Small" />
                                </VerticalStackLayout>
                            </Grid>

                            <Switch Grid.Column="1"
                                    IsToggled="{Binding IsEnabled}"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"
                                    WidthRequest="52"
                                    OnColor="{StaticResource WarmSelected}"
                                    Toggled="Switch_Toggled" />

                            <Button Grid.Row="1" Grid.ColumnSpan="2"
                                    Text=" Zeitlimit testen"
                                    BackgroundColor="Transparent"
                                    TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"
                                    HorizontalOptions="Start"
                                    Padding="8,0"
                                    HeightRequest="32"
                                    IsVisible="{Binding IsTimeLimitRule}"
                                    Clicked="TestTimeLimit_Clicked">
                                <Button.ImageSource>
                                    <FontImageSource FontFamily="FontAwesomeSolid" Glyph="&#xf0ad;" Size="16" Color="{AppThemeBinding Light=#888888, Dark=#AAAAAA}" />
                                </Button.ImageSource>
                            </Button>

                            <Border Grid.Row="2"
                                    Grid.ColumnSpan="2"
                                    IsVisible="{Binding IsSoftInterventionVisible}"
                                    Stroke="{AppThemeBinding Light=#D6D3D1, Dark=#6E6E6E}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12"
                                    BackgroundColor="{AppThemeBinding Light=#F7F7F2, Dark=#2A2A2A}">
                                <VerticalStackLayout Spacing="6">
                                    <Label Text="Soft-Intervention"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}" />
                                    <Label Text="{Binding InterventionMessage}"
                                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}" />
                                    <Label Text="{Binding StatusMessage}"
                                           FontSize="Small"
                                           TextColor="{AppThemeBinding Light=#404040, Dark=#E1E1E1}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                Text="Neue Regel"
                Clicked="AddRule_Clicked"
                CornerRadius="10"
                Padding="16,12"
                HorizontalOptions="Fill">
            <Button.ImageSource>
                <FontImageSource FontFamily="FontAwesomeSolid"
                                 Glyph="&#xf067;"
                                 Size="16"
                                 Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
            </Button.ImageSource>
        </Button>
    </Grid>
</ContentPage>
