<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Rules.RulesPage"
             Title="Regeln">
    <ContentPage.Resources>
        <!-- Karte im App-Stil: gleicher dunkler Grund wie die Page, nur beige Border grenzt ab. -->
        <Style x:Key="RuleCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource Gray950}}" />
            <Setter Property="Stroke" Value="{StaticResource WarmStroke}" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="StrokeShape" Value="RoundRectangle 14" />
        </Style>

        <!-- Pillen-Badge (z. B. Limit "30 Min/Tag"). -->
        <Style x:Key="Pill" TargetType="Border">
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="StrokeShape" Value="RoundRectangle 12" />
            <Setter Property="HorizontalOptions" Value="Start" />
        </Style>

        <!-- Umriss-Button fuer Karten-Aktionen (Bearbeiten / Intervention). -->
        <Style x:Key="CardActionButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="BorderColor" Value="{StaticResource WarmStroke}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HeightRequest" Value="36" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="6,0" />
        </Style>
    </ContentPage.Resources>

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="8,0,0,0" VerticalOptions="Center">
            <Image HeightRequest="24" WidthRequest="24" VerticalOptions="Center">
                <Image.Source>
                    <FontImageSource FontFamily="FontAwesomeSolid"
                                     Glyph="{StaticResource IconClock}"
                                     Size="22"
                                     Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
                </Image.Source>
            </Image>
            <Label Grid.Column="1"
                   Text="Regeln"
                   FontSize="24"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*,Auto" Padding="16" RowSpacing="12">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Rules}" SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource RuleCard}">
                        <VerticalStackLayout Spacing="14">

                            <!-- Kopf: Uhr-Icon + Titel/Badge + Aktiv-Schalter -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Image HeightRequest="22" WidthRequest="22" VerticalOptions="Center">
                                    <Image.Source>
                                        <FontImageSource FontFamily="FontAwesomeSolid"
                                                         Glyph="{StaticResource IconClock}"
                                                         Size="20"
                                                         Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                                    </Image.Source>
                                </Image>

                                <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontAttributes="Bold"
                                           FontSize="16"
                                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                                    <Border Style="{StaticResource Pill}"
                                            BackgroundColor="{StaticResource WarmSelected}">
                                        <Label Text="{Binding LimitBadge}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource White}" />
                                    </Border>
                                </VerticalStackLayout>

                                <Switch Grid.Column="2"
                                        IsToggled="{Binding IsEnabled}"
                                        VerticalOptions="Center"
                                        HorizontalOptions="End"
                                        WidthRequest="52"
                                        OnColor="{StaticResource WarmSelected}"
                                        Toggled="Switch_Toggled" />
                            </Grid>

                            <!-- Aktionen: Bearbeiten + Intervention, sauber nebeneinander -->
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <Button Grid.Column="0"
                                        Text="Bearbeiten"
                                        Style="{StaticResource CardActionButton}"
                                        Clicked="EditRule_Clicked">
                                    <Button.ImageSource>
                                        <FontImageSource FontFamily="FontAwesomeSolid" Glyph="&#xf044;" Size="14"
                                                         Color="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                                    </Button.ImageSource>
                                </Button>
                                <Button Grid.Column="1"
                                        Text="Intervention testen"
                                        Style="{StaticResource CardActionButton}"
                                        IsVisible="{Binding IsTimeLimitRule}"
                                        Clicked="TestTimeLimit_Clicked">
                                    <Button.ImageSource>
                                        <FontImageSource FontFamily="FontAwesomeSolid" Glyph="&#xf071;" Size="14"
                                                         Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
                                    </Button.ImageSource>
                                </Button>
                            </Grid>

                            <!-- Soft-Intervention (nach Ausloesen sichtbar), minimal: transparent, duenne Border -->
                            <Border IsVisible="{Binding IsSoftInterventionVisible}"
                                    Stroke="{StaticResource WarmStroke}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="10"
                                    BackgroundColor="Transparent">
                                <VerticalStackLayout Spacing="6">
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Image HeightRequest="16" WidthRequest="16" VerticalOptions="Center">
                                            <Image.Source>
                                                <FontImageSource FontFamily="FontAwesomeSolid" Glyph="&#xf071;" Size="14"
                                                                 Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
                                            </Image.Source>
                                        </Image>
                                        <Label Grid.Column="1"
                                               Text="Soft-Intervention"
                                               FontAttributes="Bold"
                                               FontSize="14"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                                    </Grid>
                                    <Label Text="{Binding InterventionMessage}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                                    <Label Text="{Binding StatusMessage}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="1"
                Text="Neue Regel"
                Clicked="AddRule_Clicked"
                CornerRadius="10"
                Padding="16,12"
                HorizontalOptions="Fill">
            <Button.ImageSource>
                <FontImageSource FontFamily="FontAwesomeSolid"
                                 Glyph="&#xf067;"
                                 Size="16"
                                 Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource PrimaryDarkText}}" />
            </Button.ImageSource>
        </Button>
    </Grid>
</ContentPage>
