<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Rules.EditTimeLimitRulePage"
             Title="Zeitlimit-Regel">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Speichern" Clicked="Save_Clicked" />
    </ContentPage.ToolbarItems>
    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">
            <Label Text="Aktivität / Kategorie:" FontAttributes="Bold" />
            <Entry x:Name="TargetApplicationEntry" Placeholder="z. B. Social Media" />

            <Label Text="Zeitlimit (in Minuten):" FontAttributes="Bold" />
            <Entry x:Name="TimeLimitEntry" Keyboard="Numeric" Placeholder="z. B. 30" />

            <Grid ColumnDefinitions="*,Auto">
                 <Label Text="Aktiv:" VerticalOptions="Center" FontAttributes="Bold" />
                 <Switch x:Name="IsEnabledSwitch" Grid.Column="1" VerticalOptions="Center" />
            </Grid>

            <Button x:Name="DeleteButton" Text="Regel löschen" BackgroundColor="Red" TextColor="White" Clicked="Delete_Clicked" IsVisible="False" Margin="0,32,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>