<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ReturnToMonkee.Features.PersonTest"
             x:Class="ReturnToMonkee.Features.PersonTest.PersonListPage"
             Title="Personen">
    <Grid Padding="24" RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <Button
            Text="Person erstellen"
            HorizontalOptions="Start"
            Clicked="OnCreateClicked" />

        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,*,Auto,Auto"
            ColumnSpacing="12">
            <Label Text="Vorname" FontAttributes="Bold" />
            <Label Grid.Column="1" Text="Nachname" FontAttributes="Bold" />
            <Label Grid.Column="2" Text="Bearbeiten" FontAttributes="Bold" />
            <Label Grid.Column="3" Text="Löschen" FontAttributes="Bold" />
        </Grid>

        <CollectionView
            Grid.Row="2"
            x:Name="PersonsCollectionView"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="local:Person">
                    <Grid
                        Padding="0,6"
                        ColumnDefinitions="*,*,Auto,Auto"
                        ColumnSpacing="12">
                        <Label Text="{Binding FirstName}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="{Binding LastName}" VerticalOptions="Center" />
                        <Button
                            Grid.Column="2"
                            Text="Bearbeiten"
                            Clicked="OnEditClicked"
                            CommandParameter="{Binding Id}" />
                        <Button
                            Grid.Column="3"
                            Text="Löschen"
                            Clicked="OnDeleteClicked"
                            CommandParameter="{Binding Id}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="Keine Personen gespeichert." />
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
