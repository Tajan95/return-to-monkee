<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Onboarding.GoalOrientationView"
             Shell.FlyoutBehavior="Disabled"
             Title="Zielausrichtung">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="Wähle deine Ziele"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="Diese Auswahl hilft der App, deine Empfehlungen im MVP grob einzuordnen."
                   FontSize="14"
                   TextColor="Gray" />

            <CollectionView ItemsSource="{Binding Goals}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <Border Stroke="Gray"
                                StrokeThickness="1"
                                Padding="12"
                                Margin="5">

                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="12">
                                <CheckBox IsChecked="{Binding IsSelected}" />

                                <Label Text="{Binding Title}"
                                       VerticalOptions="Center"
                                       Grid.Column="1" />
                            </Grid>

                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1"
                     BackgroundColor="LightGray"
                     Margin="0,8" />

            <Label Text="Erste Zeitlimit-Regel"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Label Text="Lege eine erste aktive Regel an, die später in der Regelübersicht angezeigt und weiter bearbeitet werden kann."
                   FontSize="14"
                   TextColor="Gray" />

            <Label Text="Kategorie"
                   FontAttributes="Bold" />

            <Picker ItemsSource="{Binding TimeLimitCategories}"
                    SelectedItem="{Binding SelectedTimeLimitCategory}" />

            <Label Text="Tägliches Zeitlimit in Minuten"
                   FontAttributes="Bold" />

            <Entry Text="{Binding TimeLimitMinutesText}"
                   Keyboard="Numeric"
                   Placeholder="z. B. 30" />

            <Label Text="{Binding ValidationMessage}"
                   TextColor="Red"
                   FontSize="14" />

            <Button Text="Weiter"
                    Command="{Binding SaveCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>