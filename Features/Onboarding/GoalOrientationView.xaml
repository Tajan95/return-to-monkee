<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Onboarding.GoalOrientationView"
             x:Name="OnboardingPage"
             Shell.FlyoutBehavior="Disabled"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}">

    <Grid RowDefinitions="*,Auto"
          Padding="24,44,24,28"
          RowSpacing="18">

        <ScrollView Grid.Row="0"
                    HorizontalOptions="FillAndExpand">
            <VerticalStackLayout Spacing="22"
                                 HorizontalOptions="FillAndExpand">

                <VerticalStackLayout IsVisible="{Binding IsWelcomeStep}"
                                     Spacing="18"
                                     VerticalOptions="Center">
                    <Grid HeightRequest="118"
                          WidthRequest="118"
                          HorizontalOptions="Center">
                        <Border BackgroundColor="{AppThemeBinding Light={StaticResource WarmSurfaceAlt}, Dark={StaticResource Gray900}}"
                                Stroke="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}"
                                StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="59" />
                            </Border.StrokeShape>
                        </Border>

                        <Image Source="monkey_face_svgrepo.png"
                               Aspect="AspectFit"
                               HeightRequest="82"
                               WidthRequest="82"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Grid>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Willkommen bei"
                               FontSize="25"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

                        <Label Text="Return To"
                               FontSize="38"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />

                        <Label Text="Monkee"
                               FontSize="38"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
                    </VerticalStackLayout>

                    <Label Text="Richte in wenigen Schritten Ziele, Pausen, Zeitlimit und Schlafenszeit ein."
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsGoalsStep}"
                                     Spacing="14">
                    <Image HeightRequest="34"
                           WidthRequest="34"
                           HorizontalOptions="Start">
                        <Image.Source>
                            <FontImageSource FontFamily="FontAwesomeSolid"
                                             Glyph="{StaticResource IconBullseye}"
                                             Size="34"
                                             Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                        </Image.Source>
                    </Image>

                    <Label Text="Welche Ziele passen zu dir?"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

                    <Label Text="Deine Auswahl hilft Return To Monkee, dir passende Empfehlungen vorzuschlagen."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

                    <CollectionView ItemsSource="{Binding Goals}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical"
                                               ItemSpacing="6" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource WarmSurface}, Dark={StaticResource Gray900}}"
                                        StrokeThickness="1"
                                        Padding="14"
                                        Margin="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding BindingContext.ToggleGoalCommand, Source={x:Reference OnboardingPage}}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmSurfaceAlt}, Dark={StaticResource WarmSelected}}" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid ColumnDefinitions="32,26,*"
                                          ColumnSpacing="12">
                                        <Grid HeightRequest="28"
                                              WidthRequest="28"
                                              HorizontalOptions="Center"
                                              VerticalOptions="Center">
                                            <Image IsVisible="True"
                                                   HeightRequest="22"
                                                   WidthRequest="22">
                                                <Image.Source>
                                                    <FontImageSource FontFamily="FontAwesomeSolid"
                                                                     Glyph="{StaticResource IconCircle}"
                                                                     Size="22"
                                                                     Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray500}}" />
                                                </Image.Source>
                                                <Image.Triggers>
                                                    <DataTrigger TargetType="Image"
                                                                 Binding="{Binding IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible" Value="False" />
                                                    </DataTrigger>
                                                </Image.Triggers>
                                            </Image>

                                            <Image IsVisible="False"
                                                   HeightRequest="24"
                                                   WidthRequest="24">
                                                <Image.Source>
                                                    <FontImageSource FontFamily="FontAwesomeSolid"
                                                                     Glyph="{StaticResource IconCircleCheck}"
                                                                     Size="24"
                                                                     Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
                                                </Image.Source>
                                                <Image.Triggers>
                                                    <DataTrigger TargetType="Image"
                                                                 Binding="{Binding IsSelected}"
                                                                 Value="True">
                                                        <Setter Property="IsVisible" Value="True" />
                                                    </DataTrigger>
                                                </Image.Triggers>
                                            </Image>
                                        </Grid>

                                        <Image Grid.Column="1"
                                               HeightRequest="20"
                                               WidthRequest="20"
                                               VerticalOptions="Center">
                                            <Image.Source>
                                                <FontImageSource FontFamily="FontAwesomeSolid"
                                                                 Glyph="{Binding Icon}"
                                                                 Size="20"
                                                                 Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                                            </Image.Source>
                                        </Image>

                                        <Label Grid.Column="2"
                                               Text="{Binding Title}"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsMovementStep}"
                                     Spacing="16">
                    <Image HeightRequest="34"
                           WidthRequest="34"
                           HorizontalOptions="Start">
                        <Image.Source>
                            <FontImageSource FontFamily="FontAwesomeSolid"
                                             Glyph="{StaticResource IconPersonWalking}"
                                             Size="34"
                                             Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                        </Image.Source>
                    </Image>

                    <Label Text="Wie oft möchtest du eine Bewegungspause?"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

                    <Label Text="Wähle ein Intervall, das sich realistisch in deinen Alltag einfügt."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

                    <!-- Aktiv-Schalter, oben/unten durch Trennlinien abgesetzt. -->
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

                    <Grid x:Name="MovementReminderToggleRow"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12"
                          HorizontalOptions="Start">
                        <Label Text="Bewegungs-Reminder aktivieren"
                               FontSize="16"
                               MaxLines="1"
                               LineBreakMode="NoWrap"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsMovementReminderEnabled, Mode=TwoWay}"
                                VerticalOptions="Center"
                                HorizontalOptions="End"
                                WidthRequest="52"
                                OnColor="{StaticResource WarmSelected}" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

                    <!-- Bei deaktiviertem Reminder: Bereich ausgegraut und gesperrt. -->
                    <Border Stroke="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}"
                            StrokeThickness="1"
                            Padding="14,10"
                            IsEnabled="{Binding IsMovementReminderEnabled}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsMovementReminderEnabled}"
                                         Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Intervall in Minuten"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                            <Picker ItemsSource="{Binding MovementReminderIntervals}"
                                    SelectedItem="{Binding SelectedMovementReminderInterval, Mode=TwoWay}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsTimeLimitStep}"
                                     Spacing="16">
                    <Image HeightRequest="34"
                           WidthRequest="34"
                           HorizontalOptions="Start">
                        <Image.Source>
                            <FontImageSource FontFamily="FontAwesomeSolid"
                                             Glyph="{StaticResource IconClock}"
                                             Size="34"
                                             Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                        </Image.Source>
                    </Image>

                    <Label Text="Lege dein erstes Zeitlimit fest"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

                    <Label Text="Diese Regel erscheint später in der Regelübersicht und kann dort weiter bearbeitet werden."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

                    <Border Stroke="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}"
                            StrokeThickness="1"
                            Padding="14,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Kategorie"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                            <Picker ItemsSource="{Binding TimeLimitCategories}"
                                    SelectedItem="{Binding SelectedTimeLimitCategory}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Stroke="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}"
                            StrokeThickness="1"
                            Padding="14,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Tägliches Zeitlimit in Minuten"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                            <Entry Text="{Binding TimeLimitMinutesText}"
                                   Keyboard="Numeric"
                                   Placeholder="z. B. 30" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding ValidationMessage}"
                           TextColor="{AppThemeBinding Light={StaticResource WarmDanger}, Dark=#FFB4AB}"
                           FontSize="14" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsSleepStep}"
                                     Spacing="16">
                    <Image HeightRequest="34"
                           WidthRequest="34"
                           HorizontalOptions="Start">
                        <Image.Source>
                            <FontImageSource FontFamily="FontAwesomeSolid"
                                             Glyph="{StaticResource IconMoon}"
                                             Size="34"
                                             Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
                        </Image.Source>
                    </Image>

                    <Label Text="Wann möchtest du schlafen gehen?"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

                    <Label Text="Diese Uhrzeit wird für deinen Schlafenszeit-Reminder verwendet."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

                    <!-- Aktiv-Schalter, oben/unten durch Trennlinien abgesetzt. -->
                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

                    <Grid x:Name="SleepReminderToggleRow"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12"
                          HorizontalOptions="Start">
                        <Label Text="Schlafenszeit-Reminder aktivieren"
                               FontSize="16"
                               MaxLines="1"
                               LineBreakMode="NoWrap"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsSleepReminderEnabled, Mode=TwoWay}"
                                VerticalOptions="Center"
                                HorizontalOptions="End"
                                WidthRequest="52"
                                OnColor="{StaticResource WarmSelected}" />
                    </Grid>

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

                    <!-- Bei deaktiviertem Reminder: Bereich ausgegraut und gesperrt. -->
                    <Border Stroke="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}"
                            StrokeThickness="1"
                            Padding="14,10"
                            IsEnabled="{Binding IsSleepReminderEnabled}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsSleepReminderEnabled}"
                                         Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Schlafenszeit"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                            <TimePicker Time="{Binding SleepTime, Mode=TwoWay}"
                                        Format="HH:mm" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsCompletedStep}"
                                     Spacing="18"
                                     VerticalOptions="Center">
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource WarmSurfaceAlt}, Dark={StaticResource Gray900}}"
                            Stroke="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
                            StrokeThickness="1"
                            HeightRequest="96"
                            WidthRequest="96"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="48" />
                        </Border.StrokeShape>
                        <Image HeightRequest="46"
                               WidthRequest="46"
                               HorizontalOptions="Center"
                               VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource FontFamily="FontAwesomeSolid"
                                                 Glyph="{StaticResource IconCircleCheck}"
                                                 Size="46"
                                                 Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
                            </Image.Source>
                        </Image>
                    </Border>

                    <Label Text="Onboarding abgeschlossen"
                           FontSize="28"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

                    <Label Text="Deine ersten Einstellungen sind gespeichert. Jetzt kannst du auf dem Dashboard starten."
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1"
                             Spacing="10">
            <ProgressBar Progress="{Binding StepProgress}"
                         ProgressColor="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
                         IsVisible="{Binding IsProgressVisible}" />

            <Label Text="{Binding StepCounterText}"
                   IsVisible="{Binding IsProgressVisible}"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
                <Button Text="Zurück"
                        Command="{Binding BackCommand}"
                        IsVisible="{Binding IsBackVisible}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource WarmSurfaceAlt}, Dark={StaticResource Gray900}}"
                        TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}"
                        BorderColor="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray500}}"
                        BorderWidth="1">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FontAwesomeSolid"
                                         Glyph="{StaticResource IconBack}"
                                         Size="14"
                                         Color="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
                    </Button.ImageSource>
                </Button>

                <Button Grid.Column="1"
                        Text="{Binding NextButtonText}"
                        Command="{Binding NextCommand}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
                        TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WarmText}}"
                        FontAttributes="Bold">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FontAwesomeSolid"
                                         Glyph="{StaticResource IconCheck}"
                                         Size="14"
                                         Color="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource WarmText}}" />
                    </Button.ImageSource>
                </Button>
            </Grid>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
