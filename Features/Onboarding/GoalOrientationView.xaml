<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Onboarding.GoalOrientationView"
             Shell.FlyoutBehavior="Disabled"
             Title="Onboarding"
             BackgroundColor="#F7F7F2">

    <Grid RowDefinitions="*,Auto"
          Padding="24,28"
          RowSpacing="18">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="22">

                <VerticalStackLayout IsVisible="{Binding IsWelcomeStep}"
                                     Spacing="18"
                                     VerticalOptions="Center">
                    <Border BackgroundColor="#1F5F4A"
                            StrokeThickness="0"
                            HeightRequest="92"
                            WidthRequest="92"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="46" />
                        </Border.StrokeShape>
                        <Label Text="RTM"
                               TextColor="White"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Willkommen bei Return To Monkee"
                           FontSize="30"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#1B1C1A" />

                    <Label Text="Richte in wenigen Schritten Ziele, Pausen, Zeitlimit und Schlafenszeit ein."
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="#51564F" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsGoalsStep}"
                                     Spacing="14">
                    <Label Text="Welche Ziele passen zu dir?"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#1B1C1A" />

                    <Label Text="Die Auswahl hilft Return To Monkee, deine Empfehlungen im MVP grob einzuordnen."
                           FontSize="14"
                           TextColor="#51564F" />

                    <CollectionView ItemsSource="{Binding Goals}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="#D7D9D2"
                                        BackgroundColor="White"
                                        StrokeThickness="1"
                                        Padding="14"
                                        Margin="0,5">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>

                                    <Grid ColumnDefinitions="Auto,*"
                                          ColumnSpacing="12">
                                        <CheckBox IsChecked="{Binding IsSelected}" />

                                        <Label Grid.Column="1"
                                               Text="{Binding Title}"
                                               FontSize="16"
                                               VerticalOptions="Center"
                                               TextColor="#252721" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsMovementStep}"
                                     Spacing="16">
                    <Label Text="Wie oft moechtest du eine Bewegungspause?"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#1B1C1A" />

                    <Label Text="Waehle ein Intervall, das sich realistisch in deinen Alltag einfuegt."
                           FontSize="14"
                           TextColor="#51564F" />

                    <Border Stroke="#D7D9D2"
                            BackgroundColor="White"
                            StrokeThickness="1"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Intervall in Minuten"
                                   FontAttributes="Bold"
                                   TextColor="#252721" />

                            <Picker ItemsSource="{Binding MovementReminderIntervals}"
                                    SelectedItem="{Binding SelectedMovementReminderInterval, Mode=TwoWay}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsTimeLimitStep}"
                                     Spacing="16">
                    <Label Text="Lege dein erstes Zeitlimit fest"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#1B1C1A" />

                    <Label Text="Diese Regel erscheint spaeter in der Regeluebersicht und kann dort weiter bearbeitet werden."
                           FontSize="14"
                           TextColor="#51564F" />

                    <Border Stroke="#D7D9D2"
                            BackgroundColor="White"
                            StrokeThickness="1"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="12">
                            <Label Text="Kategorie"
                                   FontAttributes="Bold"
                                   TextColor="#252721" />

                            <Picker ItemsSource="{Binding TimeLimitCategories}"
                                    SelectedItem="{Binding SelectedTimeLimitCategory}" />

                            <Label Text="Taegliches Zeitlimit in Minuten"
                                   FontAttributes="Bold"
                                   TextColor="#252721" />

                            <Entry Text="{Binding TimeLimitMinutesText}"
                                   Keyboard="Numeric"
                                   Placeholder="z. B. 30" />
                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding ValidationMessage}"
                           TextColor="#B42318"
                           FontSize="14" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsSleepStep}"
                                     Spacing="16">
                    <Label Text="Wann moechtest du schlafen gehen?"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#1B1C1A" />

                    <Label Text="Diese Uhrzeit wird fuer deinen Schlafenszeit-Reminder verwendet."
                           FontSize="14"
                           TextColor="#51564F" />

                    <Border Stroke="#D7D9D2"
                            BackgroundColor="White"
                            StrokeThickness="1"
                            Padding="16">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Schlafenszeit"
                                   FontAttributes="Bold"
                                   TextColor="#252721" />

                            <TimePicker Time="{Binding SleepTime, Mode=TwoWay}" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding IsCompletedStep}"
                                     Spacing="18"
                                     VerticalOptions="Center">
                    <Border BackgroundColor="#1F5F4A"
                            StrokeThickness="0"
                            HeightRequest="92"
                            WidthRequest="92"
                            HorizontalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="46" />
                        </Border.StrokeShape>
                        <Label Text="&#x2713;"
                               TextColor="White"
                               FontSize="46"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <Label Text="Onboarding abgeschlossen"
                           FontSize="28"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="#1B1C1A" />

                    <Label Text="Deine ersten Einstellungen sind gespeichert. Jetzt kannst du auf dem Dashboard starten."
                           FontSize="16"
                           HorizontalTextAlignment="Center"
                           TextColor="#51564F" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1"
                             Spacing="10">
            <ProgressBar Progress="{Binding StepProgress}"
                         ProgressColor="#1F5F4A"
                         IsVisible="{Binding IsProgressVisible}" />

            <Label Text="{Binding StepCounterText}"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   TextColor="#51564F" />

            <Grid ColumnDefinitions="Auto,*"
                  ColumnSpacing="12">
                <Button Text="Zurueck"
                        Command="{Binding BackCommand}"
                        IsVisible="{Binding IsBackVisible}"
                        BackgroundColor="#E9ECE4"
                        TextColor="#252721" />

                <Button Grid.Column="1"
                        Text="{Binding NextButtonText}"
                        Command="{Binding NextCommand}"
                        BackgroundColor="#1F5F4A"
                        TextColor="White"
                        FontAttributes="Bold" />
            </Grid>
        </VerticalStackLayout>
    </Grid>

</ContentPage>
