<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReturnToMonkee.Features.Interventions.TimeLimitInterventionPage"
             Title="Intervention">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">
            <Label Text="Zeitlimit-Simulation"
                   FontSize="28"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="16" />

            <Button Text="Zeitlimit-Überschreitung markieren"
                    Clicked="MarkExceeded_Clicked" />

            <Border IsVisible="{Binding IsSoftInterventionVisible}"
                    Stroke="{AppThemeBinding Light=#D6D3D1, Dark=#6E6E6E}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light=#F7F7F2, Dark=#2A2A2A}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Soft-Intervention"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}" />
                    <Label Text="Du hast dein gesetztes Zeitlimit erreicht."
                           TextColor="{AppThemeBinding Light=#212121, Dark=#FFFFFF}" />
                    <Label Text="Was brauchst du gerade, bevor du weitermachst?"
                           FontAttributes="Italic"
                           TextColor="{AppThemeBinding Light=#404040, Dark=#E1E1E1}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
