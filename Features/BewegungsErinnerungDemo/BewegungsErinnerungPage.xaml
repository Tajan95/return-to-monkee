<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Name="RootPage"
             x:Class="ReturnToMonkee.Features.BewegungsErinnerungDemo.BewegungsErinnerungPage"
             Title="Bewegungserinnerungen"
             BackgroundColor="Transparent">

    <ContentPage.Resources>
        <ResourceDictionary>
            <OnPlatform x:Key="PageBackgroundColor" x:TypeArguments="Color">
                <On Platform="WinUI" Value="#111010" />
                <On Platform="Android" Value="Transparent" />
                <On Platform="iOS" Value="Transparent" />
                <On Platform="MacCatalyst" Value="Transparent" />
            </OnPlatform>

            <OnPlatform x:Key="CardBackgroundColor" x:TypeArguments="Color">
                <On Platform="WinUI" Value="#1f1b24" />
                <On Platform="Android" Value="#f5f5f5" />
                <On Platform="iOS" Value="#f5f5f5" />
                <On Platform="MacCatalyst" Value="#f5f5f5" />
            </OnPlatform>

            <OnPlatform x:Key="PrimaryTextColor" x:TypeArguments="Color">
                <On Platform="WinUI" Value="#EFE8FF" />
                <On Platform="Android" Value="#000000" />
                <On Platform="iOS" Value="#000000" />
                <On Platform="MacCatalyst" Value="#000000" />
            </OnPlatform>

            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackgroundColor}" />
            </Style>

            <Style TargetType="Editor">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackgroundColor}" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackgroundColor}" />
            </Style>

            <Style TargetType="TimePicker">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackgroundColor}" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid
        RowDefinitions="2*,3*"
        RowSpacing="12"
        Padding="12"
        BackgroundColor="{StaticResource PageBackgroundColor}">

        <Grid
            Grid.Row="0"
            RowDefinitions="Auto,Auto,*"
            RowSpacing="12">

            <Label
                Grid.Row="0"
                Text="Erinnerungen"
                FontSize="24"
                FontAttributes="Bold" />

            <Label
                Grid.Row="1"
                Text="{Binding Eintraege.Count, StringFormat='Anzahl: {0}'}"
                FontSize="12"
                TextColor="{StaticResource PrimaryTextColor}" />

            <ScrollView Grid.Row="2" VerticalOptions="FillAndExpand">
                <ScrollView.HeightRequest>
                    <OnPlatform x:TypeArguments="x:Double">
                        <On Platform="WinUI" Value="340" />
                    </OnPlatform>
                </ScrollView.HeightRequest>
                <StackLayout BindableLayout.ItemsSource="{Binding Eintraege}" Spacing="4" Padding="0">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Frame BackgroundColor="{StaticResource CardBackgroundColor}" CornerRadius="6" Padding="6" HasShadow="False" Margin="0,0,0,6">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BindingContext.SelectEntryCommand, Source={x:Reference Name=RootPage}}" CommandParameter="{Binding .}" />
                                </Frame.GestureRecognizers>
                                <Frame.Triggers>
                                    <DataTrigger TargetType="Frame" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#2b2430" />
                                    </DataTrigger>
                                </Frame.Triggers>
                                <VerticalStackLayout Spacing="1">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Titel}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource PrimaryTextColor}" LineBreakMode="TailTruncation" HorizontalOptions="StartAndExpand" />
                                        <Label Grid.Column="1" Text="{Binding Id, StringFormat='ID: {0}'}" FontSize="12" TextColor="{StaticResource PrimaryTextColor}" HorizontalOptions="End" />
                                    </Grid>

                                    <Label Text="{Binding Wochentag, StringFormat='Wochentag: {0}'}" FontSize="14" TextColor="{StaticResource PrimaryTextColor}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding Wochentag}" Value="Monday">
                                                <Setter Property="Text" Value="Wochentag: Montag"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Wochentag}" Value="Tuesday">
                                                <Setter Property="Text" Value="Wochentag: Dienstag"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Wochentag}" Value="Wednesday">
                                                <Setter Property="Text" Value="Wochentag: Mittwoch"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Wochentag}" Value="Thursday">
                                                <Setter Property="Text" Value="Wochentag: Donnerstag"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Wochentag}" Value="Friday">
                                                <Setter Property="Text" Value="Wochentag: Freitag"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Wochentag}" Value="Saturday">
                                                <Setter Property="Text" Value="Wochentag: Samstag"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" Binding="{Binding Wochentag}" Value="Sunday">
                                                <Setter Property="Text" Value="Wochentag: Sonntag"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <Label Text="{Binding Erinnerungszeitpunkt, StringFormat='Zeit: {0:hh\:mm}'}" FontSize="14" TextColor="{StaticResource PrimaryTextColor}" />

                                    <Label Text="{Binding Beschreibung}" FontSize="12" TextColor="{StaticResource PrimaryTextColor}" />
                                </VerticalStackLayout>
                            </Frame>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </StackLayout>
            </ScrollView>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="12">

                <VerticalStackLayout 
                    Spacing="12" 
                    IsVisible="False"
                    BackgroundColor="{StaticResource CardBackgroundColor}"
                    Padding="12">

                    <VerticalStackLayout.Triggers>
                        <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsEditMode}" Value="True">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </VerticalStackLayout.Triggers>

                    <Label
                        Text="{Binding SelectedEntry, StringFormat='{0:Neuer Eintrag}'}"
                        FontSize="18"
                        FontAttributes="Bold" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Titel" FontSize="14" FontAttributes="Bold" />
                        <Entry Placeholder="Titel eingeben" Text="{Binding Titel, Mode=TwoWay}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Wochentag" FontSize="14" FontAttributes="Bold" />
                        <Picker Title="Wochentag auswählen" ItemsSource="{Binding Wochentage}" SelectedItem="{Binding WochentagName, Mode=TwoWay}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Erinnerungszeit" FontSize="14" FontAttributes="Bold" />
                        <TimePicker Time="{Binding Erinnerungszeitpunkt, Mode=TwoWay}" Format="HH:mm" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Beschreibung" FontSize="14" FontAttributes="Bold" />
                        <Editor Placeholder="Beschreibung eingeben" Text="{Binding Beschreibung, Mode=TwoWay}" MinimumHeightRequest="80" MaximumHeightRequest="120" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Aktiv" FontSize="14" FontAttributes="Bold" />
                            <CheckBox IsChecked="{Binding IstAktiv, Mode=TwoWay}" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>

                <Grid
                    ColumnDefinitions="*,*,*"
                    ColumnSpacing="8">

                    <Button
                        Grid.Column="0"
                        Text="Neu"
                        Clicked="OnNewClicked"
                        IsVisible="True">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="IsVisible" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button
                        Grid.Column="1"
                        Text="Speichern"
                        Clicked="OnSaveClicked"
                        IsVisible="False">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsEditMode}" Value="True">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button
                        Grid.Column="2"
                        Text="Löschen"
                        Clicked="OnDeleteClicked"
                        BackgroundColor="Red"
                        IsVisible="False">
                        <Button.Triggers>
                            <MultiTrigger TargetType="Button">
                                <MultiTrigger.Conditions>
                                    <BindingCondition Binding="{Binding IsEditMode}" Value="True" />
                                    <BindingCondition Binding="{Binding IsNewEntry}" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter Property="IsVisible" Value="True" />
                            </MultiTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button
                        Grid.Column="2"
                        Text="Abbrechen"
                        Clicked="OnCancelClicked" 
                        BackgroundColor="Gray"
                        IsVisible="False">
                        <Button.Triggers>
                            <MultiTrigger TargetType="Button">
                                <MultiTrigger.Conditions>
                                    <BindingCondition Binding="{Binding IsEditMode}" Value="True" />
                                    <BindingCondition Binding="{Binding IsNewEntry}" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter Property="IsVisible" Value="True" />
                            </MultiTrigger>
                        </Button.Triggers>
                    </Button>

                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>