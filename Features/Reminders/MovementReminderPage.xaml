<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="ReturnToMonkee.Features.Reminders.MovementReminderPage"
			 Title="Bewegung"
			 BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}">

	<Shell.TitleView>
		<Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="8,0,0,0" VerticalOptions="Center">
			<Image HeightRequest="24" WidthRequest="24" VerticalOptions="Center">
				<Image.Source>
					<FontImageSource FontFamily="FontAwesomeSolid"
									 Glyph="{StaticResource IconPersonWalking}"
									 Size="22"
									 Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
				</Image.Source>
			</Image>
			<Label Grid.Column="1"
				   Text="Bewegung"
				   FontSize="24"
				   FontAttributes="Bold"
				   VerticalOptions="Center"
				   TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
		</Grid>
	</Shell.TitleView>

	<ScrollView HorizontalOptions="FillAndExpand">
		<VerticalStackLayout Padding="24,28,24,24"
							 Spacing="16"
							 HorizontalOptions="FillAndExpand">

			<Image HeightRequest="34" WidthRequest="34" HorizontalOptions="Start">
				<Image.Source>
					<FontImageSource FontFamily="FontAwesomeSolid"
									 Glyph="{StaticResource IconPersonWalking}"
									 Size="34"
									 Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
				</Image.Source>
			</Image>

			<Label Text="Bewegungspausen"
				   FontSize="26"
				   FontAttributes="Bold"
				   TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

			<Label Text="Wähle, wie oft du an eine kurze Bewegungspause erinnert werden möchtest."
				   FontSize="14"
				   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

			<!-- Aktiv-Schalter in eigener Zeile, oben/unten durch Trennlinien abgesetzt. -->
			<BoxView HeightRequest="1"
					 Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

			<Grid x:Name="ReminderToggleRow"
				  ColumnDefinitions="*,Auto"
				  ColumnSpacing="12"
				  HorizontalOptions="Start">
				<Label Text="Bewegungs-Reminder aktiv"
					   FontSize="16"
					   MaxLines="1"
					   LineBreakMode="NoWrap"
					   VerticalOptions="Center"
					   TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
				<Switch Grid.Column="1"
						IsToggled="{Binding IsMovementReminderEnabled, Mode=TwoWay}"
						VerticalOptions="Center"
						HorizontalOptions="End"
						WidthRequest="52"
						OnColor="{StaticResource WarmSelected}" />
			</Grid>

			<BoxView HeightRequest="1"
					 Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

			<!-- Konfigurationsbereich: bei deaktiviertem Reminder ausgegraut und gesperrt. -->
			<Border Stroke="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
					BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}"
					StrokeThickness="1"
					Padding="14,10"
					IsEnabled="{Binding IsMovementReminderEnabled}">
				<Border.Triggers>
					<DataTrigger TargetType="Border"
								 Binding="{Binding IsMovementReminderEnabled}"
								 Value="False">
						<Setter Property="Opacity" Value="0.4" />
					</DataTrigger>
				</Border.Triggers>
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="4">
					<Label Text="Intervall in Minuten"
						   FontSize="13"
						   FontAttributes="Bold"
						   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
					<Picker ItemsSource="{Binding MovementReminderIntervals}"
							SelectedItem="{Binding SelectedMovementReminderInterval, Mode=TwoWay}" />
				</VerticalStackLayout>
			</Border>

			<!-- Bewusst ohne inline BackgroundColor/TextColor: der globale Button-Style
			     liefert Accent-Farbe und einen einheitlichen Disabled-Zustand. -->
			<Button Text="Speichern"
					Command="{Binding SaveCommand}"
					HorizontalOptions="Fill">
				<Button.Triggers>
					<DataTrigger TargetType="Button"
								 Binding="{Binding IsMovementReminderEnabled}"
								 Value="False">
						<Setter Property="BackgroundColor" Value="Transparent" />
						<Setter Property="BorderWidth" Value="1" />
						<Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />
						<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
						<Setter Property="Opacity" Value="0.4" />
					</DataTrigger>
				</Button.Triggers>
			</Button>

			<!-- Test nur bei aktivem Reminder; Opacity-Trigger dimmt zusaetzlich, weil die
			     inline Farben den Disabled-VisualState des globalen Styles ueberschreiben. -->
			<Button Text="Bewegungs-Reminder jetzt testen"
					Command="{Binding TestCommand}"
					HorizontalOptions="Fill"
					BackgroundColor="Transparent"
					BorderWidth="1"
					BorderColor="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}"
					TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}">
				<Button.Triggers>
					<DataTrigger TargetType="Button"
								 Binding="{Binding IsMovementReminderEnabled}"
								 Value="False">
						<Setter Property="Opacity" Value="0.4" />
					</DataTrigger>
				</Button.Triggers>
			</Button>

			<BoxView HeightRequest="1"
					 Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

			<Label Text="{Binding StatusMessage}"
				   FontSize="13"
				   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
