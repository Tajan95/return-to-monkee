<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="ReturnToMonkee.Features.Reminders.SleepReminderPage"
			 Title="Schlaf"
			 BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}">

	<ScrollView HorizontalOptions="FillAndExpand">
		<VerticalStackLayout Padding="24,28,24,24"
							 Spacing="16"
							 HorizontalOptions="FillAndExpand">

			<Image HeightRequest="34" WidthRequest="34" HorizontalOptions="Start">
				<Image.Source>
					<FontImageSource FontFamily="FontAwesomeSolid"
									 Glyph="{StaticResource IconMoon}"
									 Size="34"
									 Color="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}" />
				</Image.Source>
			</Image>

			<Label Text="Schlafenszeit"
				   FontSize="26"
				   FontAttributes="Bold"
				   TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />

			<Label Text="Diese Uhrzeit wird für deinen Schlafenszeit-Reminder verwendet."
				   FontSize="14"
				   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

			<!-- Aktiv-Schalter in eigener Zeile, oben/unten durch Trennlinien abgesetzt. -->
			<BoxView HeightRequest="1"
					 Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

			<Grid x:Name="ReminderToggleRow"
				  ColumnDefinitions="*,Auto"
				  ColumnSpacing="12"
				  HorizontalOptions="Start">
				<Label Text="Schlafenszeit-Reminder aktiv"
					   FontSize="16"
					   MaxLines="1"
					   LineBreakMode="NoWrap"
					   VerticalOptions="Center"
					   TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
				<Switch Grid.Column="1"
						IsToggled="{Binding IsSleepReminderEnabled, Mode=TwoWay}"
						VerticalOptions="Center"
						HorizontalOptions="End"
						WidthRequest="52"
						OnColor="{StaticResource WarmSelected}" />
			</Grid>

			<BoxView HeightRequest="1"
					 Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

			<!-- Konfigurationsbereich: bei deaktiviertem Reminder ausgegraut und gesperrt. -->
			<Border Stroke="{AppThemeBinding Light={StaticResource WarmAccent}, Dark={StaticResource PrimaryDark}}"
					BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}"
					StrokeThickness="1"
					Padding="14,10"
					IsEnabled="{Binding IsSleepReminderEnabled}">
				<Border.Triggers>
					<DataTrigger TargetType="Border"
								 Binding="{Binding IsSleepReminderEnabled}"
								 Value="False">
						<Setter Property="Opacity" Value="0.4" />
					</DataTrigger>
				</Border.Triggers>
				<Border.StrokeShape>
					<RoundRectangle CornerRadius="8" />
				</Border.StrokeShape>
				<VerticalStackLayout Spacing="12">
					<VerticalStackLayout Spacing="4">
						<Label Text="Schlafenszeit"
							   FontSize="13"
							   FontAttributes="Bold"
							   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
						<TimePicker Time="{Binding SleepTime, Mode=TwoWay}"
									Format="HH:mm" />
					</VerticalStackLayout>

					<VerticalStackLayout Spacing="4">
						<Label Text="Reminder-Vorlauf"
							   FontSize="13"
							   FontAttributes="Bold"
							   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
						<Picker ItemsSource="{Binding SleepReminderLeadOptions}"
								SelectedItem="{Binding SelectedSleepReminderLead, Mode=TwoWay}" />
						<Label Text="Wann vor der Schlafenszeit möchtest du erinnert werden?"
							   FontSize="12"
							   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
					</VerticalStackLayout>
				</VerticalStackLayout>
			</Border>

			<!-- Bewusst ohne inline BackgroundColor/TextColor: der globale Button-Style
			     liefert Accent-Farbe und einen einheitlichen Disabled-Zustand. -->
			<Button Text="Speichern"
					Command="{Binding SaveCommand}"
					HorizontalOptions="Fill">
				<Button.Triggers>
					<DataTrigger TargetType="Button"
								 Binding="{Binding IsSleepReminderEnabled}"
								 Value="False">
						<Setter Property="BackgroundColor" Value="Transparent" />
						<Setter Property="BorderWidth" Value="1" />
						<Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />
						<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
						<Setter Property="Opacity" Value="0.4" />
					</DataTrigger>
				</Button.Triggers>
			</Button>

			<!-- Test nur bei aktivem Reminder; Opacity-Trigger dimmt zusaetzlich, weil die
			     inline Farben den Disabled-VisualState des globalen Styles ueberschreiben. -->
			<Button Text="Schlafenszeit-Reminder jetzt testen"
					Command="{Binding TestCommand}"
					HorizontalOptions="Fill"
					BackgroundColor="Transparent"
					BorderWidth="1"
					BorderColor="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}"
					TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}">
				<Button.Triggers>
					<DataTrigger TargetType="Button"
								 Binding="{Binding IsSleepReminderEnabled}"
								 Value="False">
						<Setter Property="Opacity" Value="0.4" />
					</DataTrigger>
				</Button.Triggers>
			</Button>

			<BoxView HeightRequest="1"
					 Color="{AppThemeBinding Light={StaticResource WarmStroke}, Dark={StaticResource Gray600}}" />

			<Label Text="{Binding StatusMessage}"
				   FontSize="13"
				   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />

		</VerticalStackLayout>
	</ScrollView>
</ContentPage>
