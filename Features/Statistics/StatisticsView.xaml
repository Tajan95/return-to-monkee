<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="ReturnToMonkee.Features.Statistics.StatisticsView"
			 Title="Statistiken"
			 BackgroundColor="{AppThemeBinding Light={StaticResource PageBackgroundLight}, Dark={StaticResource PageBackgroundDark}}">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16" RowSpacing="16">

        <!-- Loading Indicator -->
        <ActivityIndicator Grid.Row="0" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        <!-- Error Message -->
        <Label Grid.Row="0" 
			   Text="{Binding ErrorMessage}" 
			   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullOrEmptyConverter}}"
			   TextColor="Red"
			   FontSize="14" />

        <!-- Heute Sektion -->
        <VerticalStackLayout Grid.Row="0" Spacing="12">
            <Label Text="Heute" FontSize="20" FontAttributes="Bold" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <!-- Limits eingehalten -->
                <Frame Grid.Row="0" Grid.Column="0" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="✓ Eingehalten" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <Label Text="{Binding TodayStatistics.LimitsKept}" 
							   FontSize="32" 
							   FontAttributes="Bold" 
							   TextColor="#4CAF50"
							   HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Limits überschritten -->
                <Frame Grid.Row="0" Grid.Column="1" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="✕ Überschritten" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <Label Text="{Binding TodayStatistics.LimitsExceeded}" 
							   FontSize="32" 
							   FontAttributes="Bold" 
							   TextColor="#F44336"
							   HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Movement Reminders Confirmed -->
                <Frame Grid.Row="1" Grid.Column="0" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Bewegung ✓" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <Label Text="{Binding TodayStatistics.MovementRemindersConfirmed}" 
							   FontSize="32" 
							   FontAttributes="Bold" 
							   TextColor="#2196F3"
							   HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Movement Reminders Ignored -->
                <Frame Grid.Row="1" Grid.Column="1" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Bewegung ✕" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <Label Text="{Binding TodayStatistics.MovementRemindersIgnored}" 
							   FontSize="32" 
							   FontAttributes="Bold" 
							   TextColor="#FF9800"
							   HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Sleep Reminder Stats -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Frame Grid.Column="0" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Schlaf ✓" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <Label Text="{Binding TodayStatistics.SleepRemindersConfirmed}" 
							   FontSize="24" 
							   FontAttributes="Bold" 
							   TextColor="#9C27B0"
							   HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Column="1" CornerRadius="12" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Schlaf ✕" FontSize="12" TextColor="Gray" HorizontalOptions="Center" />
                        <Label Text="{Binding TodayStatistics.SleepRemindersIgnored}" 
							   FontSize="24" 
							   FontAttributes="Bold" 
							   TextColor="#E91E63"
							   HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </VerticalStackLayout>

        <!-- 7-Tage-Trend Header -->
        <Label Grid.Row="1" Text="7-Tage-Trend" FontSize="20" FontAttributes="Bold" />

        <!-- 7-Tage-Trend List -->
        <CollectionView Grid.Row="2" 
					   ItemsSource="{Binding SevenDayTrend}"
					   SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="12" Margin="0,6" CornerRadius="12" HasShadow="True">
                        <Grid ColumnDefinitions="70,*" ColumnSpacing="12">
                            <!-- Date Column -->
                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding DayName}" FontSize="13" FontAttributes="Bold" />
                                <Label Text="{Binding DateFormatted}" FontSize="11" TextColor="Gray" />
                            </VerticalStackLayout>

                            <!-- Metrics Grid -->
                            <Grid Grid.Column="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <!-- Limits -->
                                <VerticalStackLayout Grid.Column="0" Spacing="4">
                                    <Label Text="Limits" FontSize="10" TextColor="Gray" />
                                    <StackLayout Orientation="Horizontal" Spacing="4">
                                        <Label Text="{Binding LimitsKeptDisplay}" FontSize="14" FontAttributes="Bold" TextColor="#4CAF50" />
                                        <Label Text="/" FontSize="12" TextColor="Gray" />
                                        <Label Text="{Binding LimitsExceededDisplay}" FontSize="14" FontAttributes="Bold" TextColor="#F44336" />
                                    </StackLayout>
                                </VerticalStackLayout>

                                <!-- Reminders -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <Label Text="Reminder" FontSize="10" TextColor="Gray" />
                                    <Label Text="{Binding TotalReminders}" FontSize="14" FontAttributes="Bold" TextColor="#2196F3" />
                                </VerticalStackLayout>

                                <!-- Quote -->
                                <VerticalStackLayout Grid.Column="2" Spacing="4">
                                    <Label Text="Quote" FontSize="10" TextColor="Gray" />
                                    <Label Text="{Binding ReminderRateDisplay}" FontSize="14" FontAttributes="Bold" TextColor="#FF9800" />
                                </VerticalStackLayout>
                            </Grid>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Refresh Button -->
        <Button Grid.Row="2" 
				Text="Aktualisieren"
				Command="{Binding LoadStatisticsCommand}"
				CornerRadius="8"
				Padding="16,12"
				VerticalOptions="End"
				HorizontalOptions="Center" />
    </Grid>
</ContentPage>