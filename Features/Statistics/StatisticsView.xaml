<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 x:Class="ReturnToMonkee.Features.Statistics.StatisticsView"
			 Title="Statistiken"
			 BackgroundColor="{AppThemeBinding Light={StaticResource WarmBackground}, Dark={StaticResource OffBlack}}">

	<ContentPage.Resources>
		<!-- Karten im App-Stil: dunkler Grund, beige/farbige Border.
		     Semantik: Salbei = positiv, Danger = ueberschritten, Accent = ignoriert/neutral. -->
		<Style x:Key="StatCard" TargetType="Border">
			<Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmSurface}, Dark={StaticResource Gray950}}" />
			<Setter Property="Stroke" Value="{StaticResource WarmStroke}" />
			<Setter Property="StrokeThickness" Value="1.5" />
			<Setter Property="Padding" Value="10" />
			<Setter Property="StrokeShape" Value="RoundRectangle 12" />
		</Style>

		<Style x:Key="StatCaption" TargetType="Label">
			<Setter Property="FontSize" Value="11" />
			<Setter Property="HorizontalOptions" Value="Center" />
			<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
		</Style>

		<Style x:Key="StatValue" TargetType="Label">
			<Setter Property="FontSize" Value="24" />
			<Setter Property="FontAttributes" Value="Bold" />
			<Setter Property="HorizontalOptions" Value="Center" />
		</Style>

		<Style x:Key="SectionHeading" TargetType="Label">
			<Setter Property="FontSize" Value="20" />
			<Setter Property="FontAttributes" Value="Bold" />
			<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
		</Style>

		<!-- 7-Tage-Trend: dunkle Karte mit beiger Border. -->
		<Style x:Key="TrendCard" TargetType="Border">
			<Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmSurface}, Dark={StaticResource Gray950}}" />
			<Setter Property="Stroke" Value="{StaticResource WarmStroke}" />
			<Setter Property="StrokeThickness" Value="1" />
			<Setter Property="Padding" Value="14" />
			<Setter Property="StrokeShape" Value="RoundRectangle 12" />
		</Style>

		<!-- Wert-Badge im Trend. -->
		<Style x:Key="TrendBadge" TargetType="Border">
			<Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WarmSurfaceAlt}, Dark={StaticResource Gray900}}" />
			<Setter Property="StrokeThickness" Value="0" />
			<Setter Property="Padding" Value="8,5" />
			<Setter Property="StrokeShape" Value="RoundRectangle 8" />
			<Setter Property="HorizontalOptions" Value="Fill" />
		</Style>

		<Style x:Key="TrendBadgeCaption" TargetType="Label">
			<Setter Property="FontSize" Value="10" />
			<Setter Property="HorizontalOptions" Value="Center" />
			<Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
		</Style>
	</ContentPage.Resources>

	<Shell.TitleView>
		<Grid ColumnDefinitions="Auto,*" ColumnSpacing="10" Padding="8,0,0,0" VerticalOptions="Center">
			<Image HeightRequest="24" WidthRequest="24" VerticalOptions="Center">
				<Image.Source>
					<FontImageSource FontFamily="FontAwesomeSolid"
									 Glyph="{StaticResource IconChartLine}"
									 Size="22"
									 Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
				</Image.Source>
			</Image>
			<Label Grid.Column="1"
				   Text="Statistiken"
				   FontSize="24"
				   FontAttributes="Bold"
				   VerticalOptions="Center"
				   TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
		</Grid>
	</Shell.TitleView>

	<Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="14">

		<!-- Heute-Sektion -->
		<VerticalStackLayout Grid.Row="0" Spacing="10">

			<ActivityIndicator IsRunning="{Binding IsBusy}"
							   IsVisible="{Binding IsBusy}"
							   Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />

			<Label Text="{Binding ErrorMessage}"
				   TextColor="{StaticResource WarmDanger}"
				   FontSize="14">
				<Label.Triggers>
					<DataTrigger TargetType="Label" Binding="{Binding ErrorMessage}" Value="">
						<Setter Property="IsVisible" Value="False" />
					</DataTrigger>
				</Label.Triggers>
			</Label>

			<Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
				<Image HeightRequest="18" WidthRequest="18" VerticalOptions="Center">
					<Image.Source>
						<FontImageSource FontFamily="FontAwesomeSolid"
										 Glyph="{StaticResource IconCalendarDay}"
										 Size="16"
										 Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
					</Image.Source>
				</Image>
				<Label Grid.Column="1" Text="Heute" Style="{StaticResource SectionHeading}" VerticalOptions="Center" />
			</Grid>

			<Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
				<!-- Limits eingehalten -->
				<Border Grid.Row="0" Grid.Column="0" Style="{StaticResource StatCard}" Stroke="{StaticResource WarmSelected}">
					<VerticalStackLayout Spacing="4">
						<Label Text="Eingehalten" Style="{StaticResource StatCaption}" />
						<Label Text="{Binding TodayStatistics.LimitsKept}"
							   Style="{StaticResource StatValue}"
							   TextColor="{StaticResource WarmSelected}" />
					</VerticalStackLayout>
				</Border>

				<!-- Limits ueberschritten -->
				<Border Grid.Row="0" Grid.Column="1" Style="{StaticResource StatCard}" Stroke="{StaticResource WarmDanger}">
					<VerticalStackLayout Spacing="4">
						<Label Text="Überschritten" Style="{StaticResource StatCaption}" />
						<Label Text="{Binding TodayStatistics.LimitsExceeded}"
							   Style="{StaticResource StatValue}"
							   TextColor="{StaticResource WarmDanger}" />
					</VerticalStackLayout>
				</Border>

				<!-- Bewegung bestaetigt -->
				<Border Grid.Row="1" Grid.Column="0" Style="{StaticResource StatCard}" Stroke="{StaticResource WarmSelected}">
					<VerticalStackLayout Spacing="4">
						<Label Text="Bewegung bestätigt" Style="{StaticResource StatCaption}" />
						<Label Text="{Binding TodayStatistics.MovementRemindersConfirmed}"
							   Style="{StaticResource StatValue}"
							   TextColor="{StaticResource WarmSelected}" />
					</VerticalStackLayout>
				</Border>

				<!-- Bewegung ignoriert -->
				<Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatCard}"
						Stroke="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}">
					<VerticalStackLayout Spacing="4">
						<Label Text="Bewegung ignoriert" Style="{StaticResource StatCaption}" />
						<Label Text="{Binding TodayStatistics.MovementRemindersIgnored}"
							   Style="{StaticResource StatValue}"
							   TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
					</VerticalStackLayout>
				</Border>

				<!-- Schlaf bestaetigt -->
				<Border Grid.Row="2" Grid.Column="0" Style="{StaticResource StatCard}" Stroke="{StaticResource WarmSelected}">
					<VerticalStackLayout Spacing="4">
						<Label Text="Schlaf bestätigt" Style="{StaticResource StatCaption}" />
						<Label Text="{Binding TodayStatistics.SleepRemindersConfirmed}"
							   Style="{StaticResource StatValue}"
							   TextColor="{StaticResource WarmSelected}" />
					</VerticalStackLayout>
				</Border>

				<!-- Schlaf ignoriert -->
				<Border Grid.Row="2" Grid.Column="1" Style="{StaticResource StatCard}"
						Stroke="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}">
					<VerticalStackLayout Spacing="4">
						<Label Text="Schlaf ignoriert" Style="{StaticResource StatCaption}" />
						<Label Text="{Binding TodayStatistics.SleepRemindersIgnored}"
							   Style="{StaticResource StatValue}"
							   TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
					</VerticalStackLayout>
				</Border>
			</Grid>
		</VerticalStackLayout>

		<!-- 7-Tage-Trend -->
		<Grid Grid.Row="1" RowDefinitions="Auto,*" RowSpacing="10" Margin="0,4,0,0">
			<Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
				<Image HeightRequest="18" WidthRequest="18" VerticalOptions="Center">
					<Image.Source>
						<FontImageSource FontFamily="FontAwesomeSolid"
										 Glyph="{StaticResource IconCalendarWeek}"
										 Size="16"
										 Color="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
					</Image.Source>
				</Image>
				<Label Grid.Column="1" Text="7-Tage-Trend" Style="{StaticResource SectionHeading}" VerticalOptions="Center" />
			</Grid>

			<CollectionView Grid.Row="1"
							ItemsSource="{Binding SevenDayTrend}"
							SelectionMode="None">
				<CollectionView.ItemsLayout>
					<LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
				</CollectionView.ItemsLayout>
				<CollectionView.ItemTemplate>
					<DataTemplate>
						<Border Style="{StaticResource TrendCard}">
							<Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
								<!-- Datum als Badge -->
								<Border Grid.Column="0" Style="{StaticResource TrendBadge}" VerticalOptions="Center" WidthRequest="58">
									<VerticalStackLayout Spacing="2" HorizontalOptions="Center">
										<Label Text="{Binding DayName}"
											   FontSize="14"
											   FontAttributes="Bold"
											   HorizontalOptions="Center"
											   TextColor="{AppThemeBinding Light={StaticResource WarmText}, Dark={StaticResource White}}" />
										<Label Text="{Binding DateFormatted}"
											   FontSize="11"
											   HorizontalOptions="Center"
											   TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
									</VerticalStackLayout>
								</Border>

								<!-- Metriken als Badges -->
								<Grid Grid.Column="1" ColumnDefinitions="*,*,*" ColumnSpacing="8">
									<!-- Limits -->
									<VerticalStackLayout Grid.Column="0" Spacing="4">
										<Label Text="Limits" Style="{StaticResource TrendBadgeCaption}" />
										<Border Style="{StaticResource TrendBadge}">
											<HorizontalStackLayout Spacing="3" HorizontalOptions="Center">
												<Label Text="{Binding LimitsKeptDisplay}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource WarmSelected}" />
												<Label Text="/" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource WarmMutedText}, Dark={StaticResource Gray200}}" />
												<Label Text="{Binding LimitsExceededDisplay}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource WarmDanger}" />
											</HorizontalStackLayout>
										</Border>
									</VerticalStackLayout>

									<!-- Reminder -->
									<VerticalStackLayout Grid.Column="1" Spacing="4">
										<Label Text="Reminder" Style="{StaticResource TrendBadgeCaption}" />
										<Border Style="{StaticResource TrendBadge}">
											<Label Text="{Binding TotalReminders}" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center"
												   TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
										</Border>
									</VerticalStackLayout>

									<!-- Quote -->
									<VerticalStackLayout Grid.Column="2" Spacing="4">
										<Label Text="Quote" Style="{StaticResource TrendBadgeCaption}" />
										<Border Style="{StaticResource TrendBadge}">
											<Label Text="{Binding ReminderRateDisplay}" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center"
												   TextColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}" />
										</Border>
									</VerticalStackLayout>
								</Grid>
							</Grid>
						</Border>
					</DataTemplate>
				</CollectionView.ItemTemplate>
			</CollectionView>
		</Grid>

		<!-- Aktualisieren -->
		<Button Grid.Row="2"
				Text="Aktualisieren"
				Command="{Binding LoadStatisticsCommand}"
				CornerRadius="10"
				Padding="16,12"
				HorizontalOptions="Fill"
				BackgroundColor="{AppThemeBinding Light={StaticResource WarmAccentDark}, Dark={StaticResource PrimaryDark}}"
				TextColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}" />
	</Grid>
</ContentPage>
