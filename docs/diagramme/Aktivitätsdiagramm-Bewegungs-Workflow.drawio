<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-05-18" version="21.0.0">
  <diagram id="bewegungs-workflow" name="Bewegungs-Workflow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Titel -->
        <mxCell id="title" value="Aktivitätsdiagramm: Bewegungs-Workflow" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="175" y="20" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- Start -->
        <mxCell id="start" value="" style="ellipse;aspect=fixed;fillColor=#666666;strokeColor=#666666;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="395" y="70" width="30" height="30" as="geometry"/>
        </mxCell>

        <!-- Intervall konfigurieren -->
        <mxCell id="config" value="Intervall konfigurieren" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="130" width="230" height="50" as="geometry"/>
        </mxCell>

        <!-- Intervall-Timer läuft -->
        <mxCell id="interval" value="Intervall-Timer läuft" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="220" width="230" height="50" as="geometry"/>
        </mxCell>

        <!-- Reminder erstellen -->
        <mxCell id="reminder" value="Reminder erstellen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="220" width="230" height="50" as="geometry"/>
        </mxCell>

        <!-- Entscheidung: Nutzer reagiert? -->
        <mxCell id="decision_react" value="Nutzer reagiert?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="295" y="310" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Ignoriert -->
        <mxCell id="ignored" value="Ignoriert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- Bestätigt -->
        <mxCell id="confirmed" value="Bestätigt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="320" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- Aktivität erfassen -->
        <mxCell id="log_activity" value="Aktivität erfassen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="430" width="230" height="50" as="geometry"/>
        </mxCell>

        <!-- Tagesfortschritt aktualisieren -->
        <mxCell id="update_progress" value="Tagesfortschritt aktualisieren" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="240" y="520" width="270" height="50" as="geometry"/>
        </mxCell>

        <!-- Entscheidung: Tagesziel erreicht? -->
        <mxCell id="decision_goal" value="Tagesziel erreicht?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="295" y="610" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Tagesziel erreicht -->
        <mxCell id="goal_reached" value="Ziel erreicht!&#xa;Erfolg anzeigen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="620" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- Ende -->
        <mxCell id="end" value="" style="ellipse;aspect=fixed;fillColor=#666666;strokeColor=#666666;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="395" y="730" width="30" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="end_ring" value="" style="ellipse;aspect=fixed;fillColor=#ffffff;strokeColor=#666666;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="387" y="722" width="46" height="46" as="geometry"/>
        </mxCell>
        <mxCell id="end_fill" value="" style="ellipse;aspect=fixed;fillColor=#666666;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="398" y="733" width="24" height="24" as="geometry"/>
        </mxCell>

        <!-- === KANTEN === -->

        <!-- Start -> Konfigurieren -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="start" target="config" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Konfigurieren -> Intervall -->
        <mxCell id="e1b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="config" target="interval" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Intervall -> Reminder -->
        <mxCell id="e2" value="Intervall abgelaufen" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="interval" target="reminder" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Reminder -> Entscheidung -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="reminder" target="decision_react" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Entscheidung -> Ignoriert -->
        <mxCell id="e4" value="ignoriert" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="decision_react" target="ignored" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="295" y="350"/>
              <mxPoint x="145" y="350"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Entscheidung -> Bestätigt -->
        <mxCell id="e5" value="bestätigt" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;" edge="1" source="decision_react" target="confirmed" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="455" y="350"/>
              <mxPoint x="605" y="350"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Ignoriert -> Zurück zu Intervall (Schleife) -->
        <mxCell id="e6" value="weiter" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;exitX=0;exitY=0.5;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="ignored" target="interval" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="50" y="345"/>
              <mxPoint x="50" y="155"/>
              <mxPoint x="260" y="155"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Bestätigt -> Aktivität erfassen -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="confirmed" target="log_activity" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="605" y="400"/>
              <mxPoint x="605" y="455"/>
              <mxPoint x="490" y="455"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Aktivität erfassen -> Tagesfortschritt -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="log_activity" target="update_progress" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tagesfortschritt -> Entscheidung Tagesziel -->
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="update_progress" target="decision_goal" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Tagesziel nein -> Zurück zu Intervall -->
        <mxCell id="e10" value="nein" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;exitX=0;exitY=0.5;" edge="1" source="decision_goal" target="interval" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="295" y="650"/>
              <mxPoint x="40" y="650"/>
              <mxPoint x="40" y="155"/>
              <mxPoint x="260" y="155"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Tagesziel ja -> Ziel erreicht -->
        <mxCell id="e11" value="ja" style="edgeStyle=orthogonalEdgeStyle;fontSize=11;exitX=1;exitY=0.5;" edge="1" source="decision_goal" target="goal_reached" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="455" y="650"/>
              <mxPoint x="605" y="650"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Ziel erreicht -> Ende -->
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="goal_reached" target="end_fill" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="605" y="700"/>
              <mxPoint x="410" y="700"/>
            </Array>
          </mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
