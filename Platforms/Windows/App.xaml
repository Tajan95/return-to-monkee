<maui:MauiWinUIApplication
    x:Class="ReturnToMonkee.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:ReturnToMonkee.WinUI">

    <maui:MauiWinUIApplication.Resources>
        <ResourceDictionary>
            <!-- Salbei-Akzent statt Windows-Blau in ComboBox/Picker-Dropdowns -->
            <SolidColorBrush x:Key="ComboBoxItemPillFillBrush" Color="#5F6B4A" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#5F6B4A" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#6B7856" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="#556042" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="White" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="White" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPressed" Color="White" />

            <!-- Salbei-Fokusstreifen statt Windows-Blau in Entry/TextBox -->
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#5F6B4A" />

            <!-- Salbei-Auswahl statt Windows-Blau im TimePicker/DatePicker-Flyout -->
            <SolidColorBrush x:Key="TimePickerFlyoutPresenterHighlightFill" Color="#5F6B4A" />
            <SolidColorBrush x:Key="DatePickerFlyoutPresenterHighlightFill" Color="#5F6B4A" />

            <!-- Shell-Flyout (WinUI NavigationView): natives Item-Chrome liefert die volle
                 Item-Breite/-Form fuer ALLE Zustaende (eine Ebene). Selected und Selected+Hover
                 bewusst FARBGLEICH -> beim Hovern ueber das aktive Item entsteht KEIN hellerer
                 Innen-Kasten. Kein Marker. -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="Transparent" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#5F6B4A" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#5F6B4A" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed" Color="#5F6B4A" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="White" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="White" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="White" />

            <!-- Nicht-selektierter Hover/Pressed: dezentes warmes Grau (volle Item-Breite/-Form). -->
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#3D372F" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed" Color="#4A4238" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="White" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundPressed" Color="White" />
        </ResourceDictionary>
    </maui:MauiWinUIApplication.Resources>

</maui:MauiWinUIApplication>
