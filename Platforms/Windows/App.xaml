<maui:MauiWinUIApplication
    x:Class="ReturnToMonkee.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:ReturnToMonkee.WinUI">

    <maui:MauiWinUIApplication.Resources>
        <ResourceDictionary>
            <!-- Salbei-Akzent statt Windows-Blau in ComboBox/Picker-Dropdowns -->
            <SolidColorBrush x:Key="ComboBoxItemPillFillBrush" Color="#5F6B4A" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelected" Color="#5F6B4A" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPointerOver" Color="#6B7856" />
            <SolidColorBrush x:Key="ComboBoxItemBackgroundSelectedPressed" Color="#556042" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelected" Color="White" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPointerOver" Color="White" />
            <SolidColorBrush x:Key="ComboBoxItemForegroundSelectedPressed" Color="White" />

            <!-- Salbei-Fokusstreifen statt Windows-Blau in Entry/TextBox -->
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#5F6B4A" />

            <!-- Salbei-Auswahl statt Windows-Blau im TimePicker/DatePicker-Flyout -->
            <SolidColorBrush x:Key="TimePickerFlyoutPresenterHighlightFill" Color="#5F6B4A" />
            <SolidColorBrush x:Key="DatePickerFlyoutPresenterHighlightFill" Color="#5F6B4A" />
        </ResourceDictionary>
    </maui:MauiWinUIApplication.Resources>

</maui:MauiWinUIApplication>
